<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Omni-Chronicle Advance Precision</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #050505; color: #f8fafc; font-family: ui-sans-serif, system-ui; }
        .panel { background: #111; border: 1px solid #222; border-radius: 1rem; }
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #050505; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #ef4444; border-radius: 10px; }
    </style>
</head>
<body class="p-4 md:p-6">
    <div class="max-w-7xl mx-auto space-y-6">
        
        <!-- Bar dei Controlli -->
        <div class="panel p-5 flex flex-col md:flex-row justify-between items-center gap-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-red-600 rounded-lg flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="13 17 18 12 13 7"></polyline><polyline points="6 17 11 12 6 7"></polyline></svg>
                </div>
                <div>
                    <h1 class="text-lg font-black uppercase italic tracking-tighter">Omni-Chronicle <span class="text-red-600">Advance</span></h1>
                    <p class="text-[9px] text-zinc-500 font-bold uppercase tracking-widest">Auto-Advance & Precision Naming</p>
                </div>
            </div>
            
            <div class="flex items-center gap-2 bg-black/50 p-2 rounded-xl border border-white/5 font-mono">
                <div class="px-3 border-r border-white/10 text-center">
                    <p class="text-[8px] text-zinc-600 font-black uppercase mb-0.5">Start</p>
                    <input type="number" id="startSec" value="0" class="bg-transparent text-sm font-bold text-red-500 outline-none w-14 text-center">
                </div>
                <div class="px-3 text-center">
                    <p class="text-[8px] text-zinc-600 font-black uppercase mb-0.5">Range</p>
                    <input type="number" id="rangeSec" value="300" class="bg-transparent text-sm font-bold text-white outline-none w-14 text-center">
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
            <!-- Sidebar Video -->
            <div class="lg:col-span-4 space-y-4">
                <div class="panel p-4 overflow-hidden">
                    <div id="dropZone" onclick="document.getElementById('videoInput').click()" class="aspect-video bg-zinc-900 border-2 border-dashed border-zinc-800 rounded-xl flex flex-col items-center justify-center cursor-pointer hover:border-red-600/40 transition-all">
                        <span id="videoStatus" class="text-[10px] font-black uppercase text-zinc-600">Trascina Video Qui</span>
                        <input type="file" id="videoInput" accept="video/*" class="hidden">
                    </div>
                    <video id="player" class="hidden w-full mt-4 rounded-lg border border-zinc-800"></video>
                </div>

                <div class="panel p-5 space-y-4">
                    <button id="runBtn" disabled class="w-full py-4 bg-red-600 hover:bg-red-500 disabled:bg-zinc-800 text-white font-black text-xs uppercase tracking-widest rounded-xl transition-all shadow-lg shadow-red-900/10">
                        Analizza & Avanza Auto
                    </button>
                    
                    <div id="progressCont" class="hidden space-y-2">
                        <div class="flex justify-between text-[8px] font-black uppercase">
                            <span id="statusLabel" class="text-zinc-500">In elaborazione...</span>
                            <span id="progressPct" class="text-red-500">0%</span>
                        </div>
                        <div class="h-1 bg-zinc-900 rounded-full overflow-hidden">
                            <div id="progressBar" class="h-full bg-red-600 w-0 transition-all"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Output area -->
            <div class="lg:col-span-8 panel flex flex-col h-[70vh] overflow-hidden">
                <div class="px-5 py-4 border-b border-zinc-900 bg-black/40 flex justify-between items-center">
                    <h2 class="text-[10px] font-black uppercase tracking-widest text-zinc-500 italic">Script & Emotional Log</h2>
                    <button onclick="copyAll()" class="text-[9px] font-black uppercase bg-zinc-800 px-4 py-2 rounded-lg hover:bg-zinc-700">Copia Script</button>
                </div>
                <div id="output" class="p-6 overflow-y-auto flex-grow custom-scrollbar font-mono text-[13px] leading-relaxed text-zinc-300">
                    <div class="text-zinc-700 italic">Pronto per l'analisi.</div>
                </div>
            </div>
        </div>
    </div>

    <canvas id="buffer" class="hidden"></canvas>

    <script>
        const apiKey = "";
        const videoInput = document.getElementById('videoInput');
        const player = document.getElementById('player');
        const runBtn = document.getElementById('runBtn');
        const output = document.getElementById('output');
        const canvas = document.getElementById('buffer');
        const ctx = canvas.getContext('2d');

        let fullScriptAccumulator = "";

        videoInput.onchange = (e) => {
            const file = e.target.files[0];
            if (file) {
                player.src = URL.createObjectURL(file);
                player.classList.remove('hidden');
                document.getElementById('videoStatus').innerText = "Video Caricato: " + file.name;
                runBtn.disabled = false;
            }
        };

        async function fetchWithRetry(url, options, retries = 5, backoff = 1000) {
            try {
                const response = await fetch(url, options);
                if (!response.ok) throw new Error(`HTTP Error: ${response.status}`);
                return await response.json();
            } catch (err) {
                if (retries > 0) {
                    await new Promise(resolve => setTimeout(resolve, backoff));
                    return fetchWithRetry(url, options, retries - 1, backoff * 2);
                }
                throw err;
            }
        }

        async function analyzeBlock(frames) {
            const systemPrompt = `Sei un trascrittore Gacha IMPECCABILE. 
            REGOLE DI NOMINAZIONE E ACCORPAMENTO:
            1. IL NOME REALE: Il nome del personaggio è sotto il rettangolo del dialogo. Usa nomi reali (Budo Masuta, Luigi, etc).
            2. FORMATO DIALOGO: "NOME: Testo". Non aggiungere emozioni ad ogni riga. Se un'emozione è fondamentale per la scena, puoi inserirla raramente prima dei due punti (es. "Bowser incazzato:").
            3. ACCORPAMENTO BATTUTE: Se lo stesso personaggio parla più volte di seguito senza interruzioni di altri personaggi, accorpa le frasi in un unico paragrafo. Esempio: "Bowser: Mario è noob. Madonna mia.".
            4. ORDINE CRONOLOGICO: Mantieni l'ordine esatto delle risposte. Se Kamek parla tra due battute di Bowser, non accorpare Bowser. Rispetta la struttura: Bowser -> Kamek -> Bowser.
            5. AZIONI: Scrivi solo l'azione (es: "Budo Masuta indica Taro Yamada"). Niente parentesi o diciture "Azione:".
            6. SCENE: Segnala "CAMBIO SCENA: [Nome]" solo la prima volta che vedi un nuovo sfondo.
            7. PULIZIA: Elimina i duplicati. Leggi tutto il testo dei box senza saltare battute.
            8. SPAZIATURA: Lascia SEMPRE una riga vuota tra una battuta (o blocco di battute dello stesso personaggio) e l'altra.
            9. PENSIERI: Se il fumetto è a nuvoletta, aggiungi (Pensa) dopo il nome: "NOME (Pensa): Testo".`;

            try {
                const data = await fetchWithRetry(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        contents: [{ parts: [{ text: "Analizza e trascrivi accorpando le battute consecutive dello stesso autore." }, ...frames.map(f => ({ inlineData: { mimeType: "image/jpeg", data: f.data } }))] }],
                        systemInstruction: { parts: [{ text: systemPrompt }] }
                    })
                });
                return data.candidates?.[0]?.content?.parts?.[0]?.text || "";
            } catch (err) { return "Errore persistente di connessione API."; }
        }

        async function generateFinalSummary(fullText) {
            const systemPrompt = `Sei un esperto di storytelling Gacha. 
            Dividi in CAPITOLI narrativi con titoli creativi. Discorso unico e fluido, senza elenchi puntati. Lingua: Italiano.`;

            try {
                const data = await fetchWithRetry(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        contents: [{ parts: [{ text: "Ecco lo script completo:\n\n" + fullText }] }],
                        systemInstruction: { parts: [{ text: systemPrompt }] }
                    })
                });
                return data.candidates?.[0]?.content?.parts?.[0]?.text || "";
            } catch (err) { return "Errore nel riassunto finale."; }
        }

        runBtn.onclick = async () => {
            runBtn.disabled = true;
            document.getElementById('progressCont').classList.remove('hidden');
            fullScriptAccumulator = "";
            
            let start = parseInt(document.getElementById('startSec').value);
            const range = parseInt(document.getElementById('rangeSec').value);
            const duration = player.duration;

            if (output.innerText.includes("Pronto")) output.innerHTML = "";

            while (start < duration) {
                const end = Math.min(start + range, duration);
                
                const divider = document.createElement('div');
                divider.className = "text-[10px] text-zinc-600 font-black border-b border-zinc-900 mt-6 mb-4 uppercase";
                divider.innerText = `>>> SEQUENZA ${start}s - ${end}s`;
                output.appendChild(divider);

                const frames = [];
                const step = 1.3; 
                
                for (let t = start; t < end; t += step) {
                    player.currentTime = t;
                    await new Promise(r => player.onseeked = r);
                    canvas.width = 1024; canvas.height = 576;
                    ctx.drawImage(player, 0, 0, 1024, 576);
                    frames.push({ data: canvas.toDataURL('image/jpeg', 0.8).split(',')[1] });

                    const progress = Math.round(((t - start) / (end - start)) * 100);
                    document.getElementById('progressBar').style.width = progress + "%";
                    document.getElementById('progressPct').innerText = progress + "%";
                }

                const result = await analyzeBlock(frames);
                fullScriptAccumulator += result + "\n\n";
                
                const blockContent = document.createElement('div');
                blockContent.className = "pl-4 border-l-2 border-red-900/20 mb-8 whitespace-pre-wrap text-zinc-300";
                blockContent.innerText = result;
                output.appendChild(blockContent);
                output.scrollTop = output.scrollHeight;

                start = end;
                document.getElementById('startSec').value = start;
                if (start >= duration) break;
            }

            const finalHeader = document.createElement('div');
            finalHeader.className = "text-center py-8 mt-10 border-t-2 border-dashed border-red-600/30";
            finalHeader.innerHTML = `<h3 class="text-red-500 font-black uppercase tracking-[0.3em] text-sm italic">Generazione Riassunto Finale...</h3>`;
            output.appendChild(finalHeader);

            const finalSummary = await generateFinalSummary(fullScriptAccumulator);
            
            const summaryContainer = document.createElement('div');
            summaryContainer.className = "p-8 bg-red-600/5 border border-red-600/20 rounded-2xl mb-12 text-zinc-200 leading-relaxed";
            summaryContainer.innerHTML = `<h2 class="text-red-500 font-black mb-6 uppercase text-center border-b border-red-600/20 pb-4">📖 RIEPILOGO COMPLETO</h2>` + 
                                         `<div class="whitespace-pre-wrap">${finalSummary}</div>`;
            output.appendChild(summaryContainer);
            output.scrollTop = output.scrollHeight;

            runBtn.disabled = false;
            document.getElementById('progressCont').classList.add('hidden');
        };

        function copyAll() {
            const el = document.createElement('textarea');
            el.value = output.innerText;
            document.body.appendChild(el);
            el.select();
            document.execCommand('copy');
            document.body.removeChild(el);
        }
    </script>
</body>
</html>
